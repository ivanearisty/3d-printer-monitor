# ============================================================
# Bambu Lab Printer Settings (required)
# ============================================================
PRINTER_ACCESS_CODE=your_access_code_here
PRINTER_SERIAL_NUMBER=your_serial_number_here
PRINTER_IP_ADDRESS=192.168.1.xxx

# ============================================================
# RTSP Camera Settings (required)
# ============================================================
CAMERA_HOST=192.168.5.77
CAMERA_PORT=554
CAMERA_USERNAME=admin
CAMERA_PASSWORD=your_camera_password
CAMERA_STREAM_PATH=stream1

# ============================================================
# Detection Settings (optional)
# ============================================================
# How often to check during printing (seconds) - default 30 minutes
CHECK_INTERVAL_PRINTING=30

# How often to check when idle (seconds)
CHECK_INTERVAL_IDLE=60

# How many consecutive detections before stopping
CONSECUTIVE_FAILURES_TO_STOP=2
